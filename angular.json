{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "workforce-app": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/workforce-app",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/favicon.ico", "src/assets"],
            "styles": ["src/styles.scss"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "optimization": true,
              "sourceMap": false,
              "extractLicenses": true
            },
            "development": { "optimization": false, "sourceMap": true }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "workforce-app:build:production" },
            "development": { "buildTarget": "workforce-app:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "turni-data-access": {
      "projectType": "library",
      "root": "projects/turni-data-access",
      "sourceRoot": "projects/turni-data-access/src",
      "prefix": "turni",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": { "project": "projects/turni-data-access/ng-package.json" }
        }
      }
    },
    "turni-shared-ui": {
      "projectType": "library",
      "root": "projects/turni-shared-ui",
      "sourceRoot": "projects/turni-shared-ui/src",
      "prefix": "turni",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": { "project": "projects/turni-shared-ui/ng-package.json" }
        }
      }
    },
    "turni-feature-dashboard": {
      "projectType": "library",
      "root": "projects/turni-feature-dashboard",
      "sourceRoot": "projects/turni-feature-dashboard/src",
      "prefix": "turni",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/turni-feature-dashboard/ng-package.json"
          }
        }
      }
    },
    "turni-feature-schedule": {
      "projectType": "library",
      "root": "projects/turni-feature-schedule",
      "sourceRoot": "projects/turni-feature-schedule/src",
      "prefix": "turni",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/turni-feature-schedule/ng-package.json"
          }
        }
      }
    },
    "turni-feature-manual-edit": {
      "projectType": "library",
      "root": "projects/turni-feature-manual-edit",
      "sourceRoot": "projects/turni-feature-manual-edit/src",
      "prefix": "turni",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/turni-feature-manual-edit/ng-package.json"
          }
        }
      }
    },
    "turni-feature-audit": {
      "projectType": "library",
      "root": "projects/turni-feature-audit",
      "sourceRoot": "projects/turni-feature-audit/src",
      "prefix": "turni",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/turni-feature-audit/ng-package.json"
          }
        }
      }
    },
    "turni-feature-validation": {
      "projectType": "library",
      "root": "projects/turni-feature-validation",
      "sourceRoot": "projects/turni-feature-validation/src",
      "prefix": "turni",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/turni-feature-validation/ng-package.json"
          }
        }
      }
    }
  }
}
